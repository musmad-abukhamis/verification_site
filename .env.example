APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=abcweb
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ---- NIN Verification Providers ----
# Live providers (Prembly / ArewaSmart proxy). ArewaSmart falls back to NIN_* if unset.
NIN_BASE_URL=https://api.prembly.com
NIN_API_KEY=
AREWASMART_BASE_URL=
AREWASMART_API_KEY=

# Placeholder providers — set *_ACTIVE=true once integrated in their service class.
PROVIDER3_ACTIVE=false
PROVIDER3_BASE_URL=
PROVIDER3_API_KEY=
PROVIDER4_ACTIVE=false
PROVIDER4_BASE_URL=
PROVIDER4_API_KEY=
PROVIDER5_ACTIVE=false
PROVIDER5_BASE_URL=
PROVIDER5_API_KEY=

# Per-provider, per-method pricing (optional overrides; defaults shown)
PREMBLY_NIN_PRICE=50
PREMBLY_PHONE_PRICE=150
PREMBLY_DEMO_PRICE=150
AREWASMART_NIN_PRICE=50
AREWASMART_PHONE_PRICE=150
AREWASMART_DEMO_PRICE=150

# ---- ArewaSmart Verification API (api.arewasmart.com.ng) ----
# Bearer-token auth. POST {base}/bvn/verify with body { "bvn": "..." }.
AREWASMART_VERIFY_BASE_URL=https://api.arewasmart.com.ng/api/v1
AREWASMART_VERIFY_TOKEN=

# ---- Billstack reserved virtual-account funding (api.billstack.co) ----
# Bearer-token auth. Used to generate a PALMPAY virtual account + BVN KYC
# upgrade. The funding webhook (x-wiaxy-signature) is verified as md5(token).
BILLSTACK_API_TOKEN=
BILLSTACK_BASE_URL=https://api.billstack.co/v2

# Termii SMS — delivers password-reset codes. Without TERMII_API_KEY the SMS
# reset silently sends nothing (it still reports success, by design, so the
# endpoint cannot be used to test which accounts exist).
TERMII_API_KEY=
TERMII_SENDER_ID="SOFT OTP"
TERMII_BASE_URL=https://v3.api.termii.com
TERMII_CHANNEL=dnd
# otp   = Termii generates and verifies the code (works on the current account)
# plain = we generate and verify it ourselves; needs plain SMS activated, which
#         currently answers 400 "Country Inactive". Prefer plain once enabled.
TERMII_MODE=otp

# ---- Live data vendor (bozavtu) ----
# Seeded into the normalized `vendors` table by VendorSeeder (driver token_style_a).
# Additional vendors + failover are configured from the admin Vendors screen.
DATA_VENDOR1_URL=https://vtu.bozavtu.com/api/data
DATA_VENDOR1_KEY=

# Sanctum: domains allowed to use session auth for /api (add your prod domain)
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1,127.0.0.1:8000
