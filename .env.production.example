# ============================================================================
# PRODUCTION environment template
# ----------------------------------------------------------------------------
# Copy this to ".env" on the server and fill in every blank/placeholder:
#   cp .env.production.example .env && php artisan key:generate
# Never commit the real ".env". See DEPLOYMENT.md for the full guide.
# ============================================================================

# ---- Core application ----
APP_NAME="ABC Services"          # drives site branding (landing page, auth, titles)
APP_ENV=production
APP_KEY=                            # generate with: php artisan key:generate
APP_DEBUG=false                     # MUST be false in production
APP_URL=https://abc.softel.ng      # your public domain (HTTPS)
ASSET_URL=https://abc.softel.ng   # serve compiled assets over HTTPS

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=12

# ---- Logging ----
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                     # keep low-noise in production

# ---- Database (PostgreSQL) ----
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=abcweb
DB_USERNAME=abcuser
DB_PASSWORD=Mu87654321                       # strong, unique password

# ---- Session (database-backed) ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.abc.softel.ng     # leading dot covers apex + www
SESSION_SECURE_COOKIE=true          # cookies only over HTTPS

# ---- Queue / Cache / Filesystem / Broadcast (no Redis required) ----
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# ---- Optional Redis (only if you switch the stores above to redis) ----
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
MEMCACHED_HOST=127.0.0.1

# ---- Mail (transactional email) ----
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---- AWS / S3 (optional; only if FILESYSTEM_DISK=s3) ----
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Read at BUILD time (npm run build). Rebuild assets if you change APP_NAME.
VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# Third-party integrations — get these from each provider's dashboard.
# ============================================================================

# ---- NIN Verification Providers ----
# Live providers (Prembly / ArewaSmart proxy). ArewaSmart falls back to NIN_* if unset.
NIN_PROVIDER=
NIN_BASE_URL=https://api.prembly.com
NIN_API_KEY=
AREWASMART_BASE_URL=
AREWASMART_API_KEY=

# NIN Verification Configuration
NIN_PROVIDER=nimc
NIN_BASE_URL=https://api.softel.ng
NIN_API_KEY=3|IvRY8jgRyXHFVQIk37p1KhVvn6vVmZoNs2EMYyCGe0a43c71

# Placeholder providers — set *_ACTIVE=true once integrated in their service class.
PROVIDER3_ACTIVE=false
PROVIDER3_BASE_URL=
PROVIDER3_API_KEY=
PROVIDER4_ACTIVE=false
PROVIDER4_BASE_URL=
PROVIDER4_API_KEY=
PROVIDER5_ACTIVE=false
PROVIDER5_BASE_URL=
PROVIDER5_API_KEY=

# Per-provider, per-method pricing (optional overrides; defaults shown)
PREMBLY_NIN_PRICE=50
PREMBLY_PHONE_PRICE=150
PREMBLY_DEMO_PRICE=150
AREWASMART_NIN_PRICE=50
AREWASMART_PHONE_PRICE=150
AREWASMART_DEMO_PRICE=150

# ---- ArewaSmart Verification API (api.arewasmart.com.ng) ----
# Bearer-token auth. POST {base}/bvn/verify with body { "bvn": "..." }.
AREWASMART_VERIFY_BASE_URL=https://api.arewasmart.com.ng/api/v1
AREWASMART_VERIFY_TOKEN=

# ---- BVN provider (if configured separately from ArewaSmart) ----
BVN_PROVIDER=
BVN_BASE_URL=
BVN_API_KEY=

# ---- Airtime / Data (VTU) ----
VTU_PROVIDER=
VTU_BASE_URL=
VTU_API_KEY=
VTU_SECRET_KEY=

# ---- Data vending vendor #1 (bozavtu) ----
# Seeded into the vendorapi table. Token auth; {network,phone,bypass,data_plan} body.
DATA_VENDOR1_URL=https://vtu.bozavtu.com/api/data
DATA_VENDOR1_KEY=

# ---- Quicklysim (data vendor #5) ----
# Access token fetched per-request via Basic auth against {base}/user.
QUICKLYSIM_BASE_URL=https://quicklysim.com/api
QUICKLYSIM_USERNAME=
QUICKLYSIM_PASSWORD=

# ---- Payments: Paystack ----
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# ---- Wallet funding: Billstack reserved virtual-account (api.billstack.co) ----
# Bearer-token auth. Generates a PALMPAY virtual account + BVN KYC upgrade.
# Webhook URL: https://your-domain.com/api/webhooks/billstack
# The funding webhook (x-wiaxy-signature) is verified as md5(token).
BILLSTACK_API_TOKEN=
BILLSTACK_BASE_URL=https://api.billstack.co/v2

# ---- Sanctum: domains allowed to use session auth for /api ----
SANCTUM_STATEFUL_DOMAINS=your-domain.com,www.your-domain.com
